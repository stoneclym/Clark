# Supabase — from your project's API settings
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Canvas LMS — your school's Canvas domain (no trailing slash)
VITE_CANVAS_URL=https://myschool.instructure.com

# Copy this file to .env.local and fill in your values.
# The Anthropic API key goes into Supabase as a secret — see SETUP.md.
